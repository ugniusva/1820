<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>1820 | Restaurant</title>
  <style>
    :root {
      --paper: #f3f3f3;
      --ink: #070707;
      --graphite: #2f2f2f;
      --soft: #b9b9b9;
      --progress: 0;
      --veil: 0;
      --story: 0;
      --interlude: 0;
      --booking: 0;
      --mark: 0;
    }

    * {
      box-sizing: border-box;
    }

    html {
      background: var(--paper);
      color: var(--ink);
      scroll-behavior: auto;
    }

    body {
      min-height: 100vh;
      margin: 0;
      overflow-x: hidden;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      letter-spacing: 0;
      background:
        repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.025) 0 1px, transparent 1px 8px),
        linear-gradient(180deg, #f6f6f6 0%, #ececec 48%, #d8d8d8 100%);
    }

    body::after {
      content: "";
      position: fixed;
      inset: 0;
      z-index: 30;
      pointer-events: none;
      opacity: 0.24;
      background:
        repeating-radial-gradient(circle at 24% 34%, rgba(0, 0, 0, 0.08) 0 1px, transparent 1px 5px),
        repeating-linear-gradient(112deg, rgba(0, 0, 0, 0.03) 0 1px, transparent 1px 7px);
      mix-blend-mode: multiply;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button,
    a {
      -webkit-tap-highlight-color: transparent;
    }

    .scroll-length {
      height: 820vh;
      pointer-events: none;
    }

    .stage {
      position: fixed;
      inset: 0;
      isolation: isolate;
      overflow: hidden;
      background:
        radial-gradient(circle at 50% 48%, rgba(255, 255, 255, 0.94), transparent 18vw),
        radial-gradient(circle at 22% 84%, rgba(0, 0, 0, 0.1), transparent 32vw),
        #f3f3f3;
    }

    .stage::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      opacity: calc(var(--veil) * 0.92);
      background: rgba(244, 244, 244, 0.86);
    }

    .stage::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      opacity: 0.58;
      background:
        linear-gradient(90deg, rgba(0, 0, 0, 0.055) 1px, transparent 1px) 0 0 / clamp(42px, 7vw, 110px) clamp(42px, 7vw, 110px),
        linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.08));
    }

    .topbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 20;
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 76px;
      padding: 20px clamp(18px, 4vw, 58px);
      color: #ffffff;
      mix-blend-mode: difference;
    }

    .brand,
    .date {
      font-size: clamp(0.72rem, 0.68rem + 0.16vw, 0.86rem);
      font-weight: 850;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .brand {
      font-size: clamp(1rem, 0.86rem + 0.56vw, 1.42rem);
      letter-spacing: 0.02em;
    }

    .hero-copy {
      position: fixed;
      inset: 0;
      z-index: 8;
      display: grid;
      place-items: center;
      padding: 8rem clamp(18px, 4vw, 58px) 9rem;
      text-align: center;
      pointer-events: none;
      opacity: clamp(0, calc(1 - ((var(--progress) - 0.045) * 8.5)), 1);
      transform: translateY(calc(var(--progress) * -7vh)) scale(calc(1 - (var(--progress) * 0.045)));
    }

    .brand-watermark {
      position: fixed;
      inset: 0;
      z-index: 11;
      display: grid;
      place-items: center;
      padding: 8rem clamp(18px, 4vw, 58px) 9rem;
      pointer-events: none;
      color: #080808;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(7.2rem, 20vw, 19rem);
      font-weight: 400;
      line-height: 0.76;
      letter-spacing: 0;
      opacity: var(--mark);
      transform: translateY(-1vh);
    }

    .eyebrow {
      margin: 0 0 clamp(18px, 3vw, 34px);
      font-size: clamp(0.7rem, 0.65rem + 0.2vw, 0.86rem);
      font-weight: 850;
      letter-spacing: 0.18em;
      line-height: 1.4;
      text-transform: uppercase;
      color: #505050;
    }

    h1 {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(7.2rem, 20vw, 19rem);
      font-weight: 400;
      line-height: 0.76;
      letter-spacing: 0;
      color: #080808;
    }

    .subline {
      max-width: 34rem;
      margin: clamp(22px, 4vw, 46px) auto 0;
      font-size: clamp(0.92rem, 0.82rem + 0.36vw, 1.18rem);
      font-weight: 620;
      line-height: 1.5;
      color: #222222;
    }

    .balloon-field {
      position: absolute;
      inset: -12vh 0;
      z-index: 4;
      pointer-events: none;
      filter: grayscale(1) contrast(1.08);
    }

    .balloon {
      position: absolute;
      left: 0;
      top: 0;
      width: var(--size);
      height: calc(var(--size) * 1.22);
      opacity: var(--alpha, 0);
      transform:
        translate3d(
          calc(var(--x) * 1vw),
          calc(var(--y) * 1vh),
          0
        )
        translate(-50%, -50%)
        rotate(var(--rot))
        scale(var(--scale, 1));
      transform-origin: 50% 58%;
      will-change: transform, opacity;
    }

    .balloon::before,
    .balloon::after,
    .balloon .sketch {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: var(--radius);
    }

    .balloon::before {
      border: var(--stroke) solid var(--line);
      background:
        radial-gradient(circle at 29% 22%, rgba(255, 255, 255, 0.76) 0 6%, transparent 7%),
        repeating-linear-gradient(var(--angle-a), rgba(0, 0, 0, var(--grain-a)) 0 1px, transparent 1px 5px),
        repeating-linear-gradient(var(--angle-b), rgba(255, 255, 255, var(--grain-b)) 0 1px, transparent 1px 7px),
        linear-gradient(145deg, var(--tone-a), var(--tone-b) 56%, var(--tone-c));
      box-shadow:
        inset -12px -18px 0 rgba(0, 0, 0, var(--flat-shade)),
        inset 10px 8px 0 rgba(255, 255, 255, var(--flat-light)),
        0 14px 32px rgba(0, 0, 0, 0.11);
    }

    .balloon::after {
      inset: 9% 14% 12% 12%;
      border: 1px solid rgba(255, 255, 255, 0.22);
      background:
        repeating-linear-gradient(calc(var(--angle-a) + 42deg), transparent 0 4px, rgba(0, 0, 0, 0.08) 4px 5px);
      mix-blend-mode: multiply;
      opacity: 0.72;
    }

    .balloon .sketch {
      border: calc(var(--stroke) * 0.72) solid var(--line);
      opacity: 0.68;
      transform: translate(var(--jitter-x), var(--jitter-y)) rotate(var(--sketch-rot));
    }

    .balloon .sketch-b {
      inset: 2px -2px -1px 1px;
      opacity: 0.38;
      transform: translate(calc(var(--jitter-x) * -1), calc(var(--jitter-y) * 0.7)) rotate(calc(var(--sketch-rot) * -1));
    }

    .balloon .knot {
      position: absolute;
      left: 50%;
      top: calc(100% - 3px);
      width: calc(var(--size) * 0.11);
      height: calc(var(--size) * 0.1);
      transform: translateX(-50%);
      clip-path: polygon(50% 0, 100% 100%, 0 100%);
      background:
        repeating-linear-gradient(35deg, rgba(255, 255, 255, 0.18) 0 1px, transparent 1px 4px),
        var(--tone-c);
      border: 1px solid var(--line);
    }

    .balloon .string {
      position: absolute;
      top: calc(100% + (var(--size) * 0.07));
      left: 50%;
      width: 1px;
      height: calc(var(--size) * 0.62);
      transform: translateX(-50%) rotate(calc(var(--rot) * -0.32));
      transform-origin: top center;
      background:
        repeating-linear-gradient(180deg, rgba(0, 0, 0, 0.44) 0 2px, transparent 2px 5px);
      opacity: 0.5;
    }

    .balloon.variant-outline::before {
      background:
        repeating-linear-gradient(var(--angle-a), rgba(0, 0, 0, 0.08) 0 1px, transparent 1px 5px),
        rgba(255, 255, 255, 0.08);
      box-shadow:
        inset -8px -10px 0 rgba(0, 0, 0, 0.04),
        0 10px 22px rgba(0, 0, 0, 0.07);
    }

    .balloon.variant-black::before {
      border-color: rgba(0, 0, 0, 0.92);
    }

    .restaurant-panel,
    .detail-panel,
    .booking-panel {
      position: fixed;
      inset: 0;
      z-index: 12;
      display: grid;
      align-content: center;
      gap: clamp(26px, 5vh, 52px);
      padding: clamp(92px, 12vh, 136px) clamp(18px, 5vw, 72px) clamp(28px, 6vh, 72px);
      pointer-events: none;
    }

    .restaurant-panel {
      opacity: var(--story);
      transform: translateY(calc((1 - var(--story)) * 28px));
    }

    .detail-panel {
      z-index: 13;
      opacity: var(--interlude);
      transform: translateX(calc((1 - var(--interlude)) * -34px));
    }

    .booking-panel {
      z-index: 14;
      align-content: end;
      color: #f5f5f5;
      opacity: var(--booking);
      transform: translateY(calc((1 - var(--booking)) * 46px));
    }

    .booking-panel::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -2;
      background:
        repeating-linear-gradient(110deg, rgba(255, 255, 255, 0.035) 0 1px, transparent 1px 6px),
        #080808;
      transform: scaleY(var(--booking));
      transform-origin: bottom;
    }

    .booking-panel::after {
      content: "1820";
      position: absolute;
      inset: 0;
      z-index: -1;
      display: grid;
      place-items: center;
      padding: 8rem clamp(18px, 4vw, 58px) 9rem;
      color: #f5f5f5;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(7.2rem, 20vw, 19rem);
      font-weight: 400;
      line-height: 0.76;
      letter-spacing: 0;
      opacity: calc(var(--booking) * 0.055);
      pointer-events: none;
      transform: translateY(-1vh);
    }

    .page-transition {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      height: 100dvh;
      z-index: 80;
      display: grid;
      place-items: center;
      background: #f7f7f7;
      opacity: 0;
      pointer-events: none;
      transition: opacity 920ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .page-transition.is-active {
      opacity: 1;
      pointer-events: auto;
    }

    .rock-loader {
      position: relative;
      width: clamp(54px, 6vw, 92px);
      aspect-ratio: 1.24;
      opacity: 0;
      transform: rotate(-7deg);
      transform-origin: center;
      filter: grayscale(1);
      animation: rockBlink 980ms ease-in-out infinite;
    }

    .page-transition.is-active .rock-loader {
      opacity: 0.9;
    }

    .rock-loader::before,
    .rock-loader::after {
      content: "";
      position: absolute;
      inset: 0;
      clip-path: polygon(18% 29%, 43% 9%, 76% 19%, 93% 52%, 73% 88%, 29% 91%, 7% 62%);
    }

    .rock-loader::before {
      background:
        repeating-linear-gradient(118deg, rgba(255, 255, 255, 0.28) 0 1px, transparent 1px 6px),
        linear-gradient(135deg, #e8e8e8, #9c9c9c 58%, #2b2b2b);
      border: 2px solid #111111;
      box-shadow: 10px 10px 0 rgba(0, 0, 0, 0.16);
    }

    .rock-loader::after {
      inset: 7% 10% 14% 12%;
      background:
        repeating-linear-gradient(32deg, rgba(0, 0, 0, 0.18) 0 1px, transparent 1px 5px);
      opacity: 0.48;
      mix-blend-mode: multiply;
    }

    @keyframes rockBlink {
      0%,
      100% {
        opacity: 0.28;
        transform: rotate(-7deg);
      }

      48% {
        opacity: 0.92;
        transform: rotate(-7deg);
      }
    }

    .restaurant-panel.is-live,
    .detail-panel.is-live,
    .booking-panel.is-live {
      pointer-events: auto;
    }

    .story-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(250px, 0.58fr);
      gap: clamp(30px, 8vw, 120px);
      align-items: end;
      width: min(100%, 1260px);
      margin: 0 auto;
    }

    .story-kicker,
    .story-meta,
    .reserve-link {
      font-size: clamp(0.68rem, 0.62rem + 0.18vw, 0.82rem);
      font-weight: 900;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .story-kicker {
      margin: 0 0 18px;
      color: #3c3c3c;
    }

    .story-title {
      max-width: 11ch;
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(4rem, 12vw, 12rem);
      font-weight: 400;
      line-height: 0.86;
      letter-spacing: 0;
    }

    .story-copy {
      display: grid;
      gap: clamp(18px, 3vw, 30px);
      padding-bottom: 0.9rem;
    }

    .story-copy p {
      max-width: 33rem;
      margin: 0;
      color: #171717;
      font-size: clamp(1rem, 0.88rem + 0.48vw, 1.38rem);
      font-weight: 560;
      line-height: 1.52;
    }

    .detail-layout {
      display: grid;
      grid-template-columns: minmax(260px, 0.72fr) minmax(0, 1fr);
      gap: clamp(30px, 7vw, 94px);
      align-items: end;
      width: min(100%, 1260px);
      margin: 0 auto;
    }

    .detail-title,
    .booking-title {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(4rem, 9.8vw, 9rem);
      font-weight: 400;
      line-height: 0.86;
      letter-spacing: 0;
    }

    .detail-title {
      max-width: 7.4ch;
    }

    .detail-copy {
      display: grid;
      gap: clamp(18px, 3vw, 30px);
    }

    .detail-copy p,
    .booking-copy p {
      max-width: 39rem;
      margin: 0;
      font-size: clamp(1rem, 0.9rem + 0.44vw, 1.34rem);
      font-weight: 580;
      line-height: 1.5;
    }

    .story-details {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      width: min(100%, 1260px);
      margin: 0 auto;
      border: 1px solid rgba(0, 0, 0, 0.34);
      background: rgba(0, 0, 0, 0.28);
    }

    .story-item {
      min-height: clamp(112px, 15vh, 158px);
      padding: clamp(18px, 2.4vw, 28px);
      background:
        repeating-linear-gradient(112deg, rgba(0, 0, 0, 0.035) 0 1px, transparent 1px 5px),
        rgba(244, 244, 244, 0.82);
    }

    .story-item b {
      display: block;
      margin-bottom: 18px;
      font-size: clamp(0.68rem, 0.62rem + 0.16vw, 0.82rem);
      font-weight: 900;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .story-item span {
      display: block;
      max-width: 22rem;
      color: #222222;
      font-size: clamp(0.92rem, 0.84rem + 0.24vw, 1.06rem);
      font-weight: 560;
      line-height: 1.48;
    }

    .story-meta {
      color: #555555;
    }

    .booking-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(250px, 0.46fr);
      gap: clamp(30px, 8vw, 112px);
      align-items: end;
      width: min(100%, 1260px);
      margin: 0 auto;
    }

    .booking-title {
      max-width: 8ch;
      color: #f5f5f5;
    }

    .booking-copy {
      display: grid;
      gap: clamp(18px, 3vw, 30px);
      color: #e7e7e7;
    }

    .booking-copy .story-meta {
      color: #bdbdbd;
    }

    .reserve-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: min(100%, 330px);
      min-height: 62px;
      padding: 20px 28px;
      border: 2px solid #080808;
      background:
        repeating-linear-gradient(110deg, rgba(0, 0, 0, 0.05) 0 1px, transparent 1px 5px),
        #f2f2f2;
      color: #080808;
      box-shadow: 8px 8px 0 #080808;
      transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }

    .booking-panel .reserve-link {
      border-color: #f5f5f5;
      background:
        repeating-linear-gradient(110deg, rgba(0, 0, 0, 0.05) 0 1px, transparent 1px 5px),
        #f5f5f5;
      box-shadow: 8px 8px 0 #5e5e5e;
    }

    .reserve-link:hover,
    .reserve-link:focus-visible {
      transform: translate(4px, 4px);
      box-shadow: 4px 4px 0 #080808;
      background: #ffffff;
      outline: none;
    }

    .progress-rail {
      position: fixed;
      right: clamp(18px, 3vw, 38px);
      top: 50%;
      z-index: 21;
      width: 1px;
      height: min(32vh, 260px);
      transform: translateY(-50%);
      background: rgba(0, 0, 0, 0.22);
      pointer-events: none;
      mix-blend-mode: multiply;
    }

    .progress-rail::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: 0;
      width: 1px;
      height: calc(var(--progress) * 100%);
      background: #080808;
    }

    .skip {
      position: fixed;
      right: clamp(8px, 1.8vw, 22px);
      top: calc(50% + min(20vh, 160px));
      z-index: 22;
      display: inline-grid;
      place-items: center;
      width: 38px;
      min-height: 112px;
      padding: 10px 0;
      border: 2px solid #090909;
      border-radius: 0;
      background: #090909;
      color: #f7f7f7;
      cursor: pointer;
      font: 900 0.67rem/1 Inter, ui-sans-serif, system-ui, sans-serif;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      writing-mode: vertical-rl;
      box-shadow: 0 12px 34px rgba(0, 0, 0, 0.16);
    }

    .skip:hover,
    .skip:focus-visible {
      background: #f3f3f3;
      color: #080808;
      outline: none;
    }

    @media (max-width: 760px) {
      .scroll-length {
        height: 760vh;
      }

      .topbar {
        min-height: 68px;
        padding: 18px 20px;
      }

      .date {
        display: none;
      }

      .hero-copy {
        align-items: start;
        padding-top: 24vh;
      }

      h1 {
        font-size: clamp(6rem, 33vw, 10rem);
      }

      .subline {
        max-width: 21rem;
      }

      .restaurant-panel,
      .detail-panel,
      .booking-panel {
        align-content: end;
        padding: 68px 20px 18px;
        gap: 14px;
      }

      .story-grid,
      .detail-layout,
      .booking-layout {
        grid-template-columns: 1fr;
        gap: 20px;
      }

      .story-title {
        max-width: 9ch;
        font-size: clamp(2.9rem, 15vw, 4.9rem);
        line-height: 0.88;
      }

      .detail-title,
      .booking-title {
        max-width: 8ch;
        font-size: clamp(2.9rem, 15vw, 4.9rem);
        line-height: 0.88;
      }

      .story-copy,
      .detail-copy,
      .booking-copy {
        gap: 12px;
        padding-bottom: 0;
        padding-right: 46px;
      }

      .story-details {
        grid-template-columns: 1fr;
        margin-right: 46px;
        width: auto;
      }

      .story-item {
        min-height: 72px;
        padding: 13px 14px;
      }

      .story-item b {
        margin-bottom: 6px;
      }

      .story-copy p,
      .detail-copy p,
      .booking-copy p {
        font-size: 0.95rem;
        line-height: 1.42;
      }

      .story-kicker {
        margin-bottom: 8px;
      }

      .story-item span {
        font-size: 0.88rem;
        line-height: 1.36;
      }

      .reserve-link {
        width: 100%;
        min-height: 58px;
      }

      .progress-rail {
        right: 20px;
        height: 22vh;
      }

      .skip {
        right: 7px;
        width: 34px;
        min-height: 96px;
        font-size: 0.62rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      html {
        scroll-behavior: auto;
      }

      .reserve-link {
        transition: none;
      }
    }
  </style>
</head>
<body>
  <div class="stage" aria-hidden="true">
    <div class="balloon-field" id="balloonField"></div>
  </div>
  <div class="brand-watermark" aria-hidden="true">1820</div>
  <div class="page-transition" id="pageTransition" aria-hidden="true">
    <div class="rock-loader"></div>
  </div>

  <header class="topbar" aria-label="Site header">
    <a class="brand" href="index.html" aria-label="1820 home">1820</a>
    <div class="date">Monochrome Service</div>
  </header>

  <main>
    <section class="hero-copy" aria-label="1820 landing">
      <div>
        <p class="eyebrow">Evenings lifted in silence</p>
        <h1>1820</h1>
        <p class="subline">A room of black, white, glass, air, and measured celebration.</p>
      </div>
    </section>

    <section class="restaurant-panel" id="restaurantPanel" aria-label="Restaurant introduction">
      <div class="story-grid">
        <div>
          <p class="story-kicker">After the room fills</p>
          <h2 class="story-title">Dinner, held quietly.</h2>
        </div>
        <div class="story-copy">
          <p>1820 is a restrained dining room built around slow service, polished glass, graphite shadows, and tables spaced for private conversation.</p>
          <p class="story-meta">Monochrome evenings. Low light. Slow courses. Private conversation.</p>
        </div>
      </div>
    </section>

    <section class="detail-panel" id="detailPanel" aria-label="Dining room notes">
      <div class="detail-layout">
        <div>
          <p class="story-kicker">The room settles</p>
          <h2 class="detail-title">Glass, graphite, silence.</h2>
        </div>
        <div class="detail-copy">
          <p>This section can hold menu notes, opening hours, a chef statement, private dining copy, or whatever comes next once the visual moment has cleared.</p>
          <p class="story-meta">For now it is a polished placeholder with enough weight to feel like part of the page.</p>
        </div>
      </div>
      <div class="story-details" aria-label="Restaurant details">
        <div class="story-item">
          <b>Private tables</b>
          <span>Wide spacing, low voices, and service that moves without interrupting the room.</span>
        </div>
        <div class="story-item">
          <b>Graphite bar</b>
          <span>Glass, steel, and monochrome pours before dinner or after the last course.</span>
        </div>
        <div class="story-item">
          <b>Late seating</b>
          <span>A smaller final sitting for longer evenings, celebrations, and quiet returns.</span>
        </div>
      </div>
    </section>

    <section class="booking-panel" id="bookingPanel" aria-label="Reservation call to action">
      <div class="booking-layout">
        <div>
          <p class="story-kicker">Final sitting</p>
          <h2 class="booking-title">Hold the evening.</h2>
        </div>
        <div class="booking-copy">
          <p>Choose the table, the hour, and the tone of the night. The room is small by design.</p>
          <p class="story-meta">Reservation only. Limited seats.</p>
          <a class="reserve-link" href="reservation.html" data-page-transition>Booking</a>
        </div>
      </div>
    </section>
  </main>

  <div class="progress-rail" aria-hidden="true"></div>
  <button class="skip" id="skipToEnd" type="button">Bottom</button>
  <div class="scroll-length" aria-hidden="true"></div>

  <script>
    (() => {
      const root = document.documentElement;
      const field = document.getElementById("balloonField");
      const panel = document.getElementById("restaurantPanel");
      const detailPanel = document.getElementById("detailPanel");
      const bookingPanel = document.getElementById("bookingPanel");
      const skip = document.getElementById("skipToEnd");
      const pageTransition = document.getElementById("pageTransition");
      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const clamp = (value, min = 0, max = 1) => Math.min(max, Math.max(min, value));
      const smooth = (value) => value * value * (3 - 2 * value);
      const lerp = (from, to, amount) => from + (to - from) * amount;

      const getMaxScroll = () => {
        const pageHeight = Math.max(document.body.scrollHeight, document.documentElement.scrollHeight);
        return Math.max(1, pageHeight - window.innerHeight);
      };

      function mulberry32(seed) {
        return function random() {
          let t = seed += 0x6D2B79F5;
          t = Math.imul(t ^ (t >>> 15), t | 1);
          t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
          return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
        };
      }

      const random = mulberry32(1820);
      const isNarrow = () => window.matchMedia("(max-width: 760px)").matches;
      let narrow = isNarrow();
      const columns = 14;
      const rows = 10;
      const palette = [
        {
          name: "variant-outline",
          a: "rgba(255, 255, 255, 0.1)",
          b: "rgba(235, 235, 235, 0.36)",
          c: "rgba(180, 180, 180, 0.22)",
          line: "rgba(12, 12, 12, 0.64)",
          shade: 0.04,
          light: 0.32,
          grainA: 0.12,
          grainB: 0.16
        },
        {
          name: "variant-paper",
          a: "#ffffff",
          b: "#d8d8d8",
          c: "#aaaaaa",
          line: "rgba(15, 15, 15, 0.58)",
          shade: 0.08,
          light: 0.46,
          grainA: 0.12,
          grainB: 0.2
        },
        {
          name: "variant-smoke",
          a: "#dedede",
          b: "#8d8d8d",
          c: "#424242",
          line: "rgba(4, 4, 4, 0.7)",
          shade: 0.14,
          light: 0.22,
          grainA: 0.14,
          grainB: 0.12
        },
        {
          name: "variant-black",
          a: "#8d8d8d",
          b: "#2a2a2a",
          c: "#050505",
          line: "rgba(0, 0, 0, 0.92)",
          shade: 0.18,
          light: 0.12,
          grainA: 0.18,
          grainB: 0.1
        }
      ];

      const cells = Array.from({ length: columns * rows }, (_, index) => {
        const col = index % columns;
        const row = Math.floor(index / columns);
        const x = ((col + 0.5) / columns) * 100 + (random() - 0.5) * 8;
        const y = ((row + 0.5) / rows) * 100 + (random() - 0.5) * 8;
        const dx = x - 50;
        const dy = y - 50;
        return {
          x,
          y,
          distance: Math.sqrt((dx * dx) + (dy * dy)),
          order: random()
        };
      }).sort((a, b) => (a.distance * 0.72 + a.order * 32) - (b.distance * 0.72 + b.order * 32));

      const edgeCells = [
        { x: -3, y: 8 }, { x: 104, y: 10 }, { x: 5, y: 94 }, { x: 100, y: 92 },
        { x: 20, y: -3 }, { x: 80, y: -2 }, { x: 34, y: 104 }, { x: 68, y: 103 },
        { x: -4, y: 48 }, { x: 108, y: 30 }, { x: 106, y: 52 }, { x: 109, y: 74 },
        { x: 50, y: -5 }, { x: 50, y: 106 }, { x: 114, y: 18 }, { x: 114, y: 87 }
      ].map((cell) => ({
        ...cell,
        edge: true,
        distance: Math.hypot(cell.x - 50, cell.y - 50),
        order: random()
      }));

      const clusterSeeds = [
        { x: 53, y: 32 }, { x: 57, y: 34 }, { x: 61, y: 38 }, { x: 55, y: 41 },
        { x: 63, y: 44 }, { x: 50, y: 45 }, { x: 58, y: 48 }
      ];

      const balloons = cells.concat(edgeCells).map((cell, index, all) => {
        const cellProgress = index / Math.max(1, all.length - 1);
        const cluster = clusterSeeds[index % clusterSeeds.length];
        const tone = palette[Math.floor(random() * palette.length)];
        const edgeBoost = cell.edge ? (cell.x > 100 || cell.x < 0 ? 1.42 : 1.28) : 1;
        const sizeBase = lerp(70, 194, Math.pow(random(), 0.68)) * edgeBoost;
        const originRadius = lerp(0.5, 6.5, random());
        const originAngle = random() * Math.PI * 2;
        const originX = cluster.x + Math.cos(originAngle) * originRadius;
        const originY = cluster.y + Math.sin(originAngle) * originRadius * 0.72;
        const appear = 0.035 + cellProgress * 0.085 + random() * 0.01;
        const release = appear + lerp(0.006, 0.032, random());
        const duration = lerp(0.085, 0.135, random());
        const rotation = `${lerp(-10, 10, random()).toFixed(2)}deg`;

        const el = document.createElement("div");
        el.className = `balloon ${tone.name}`;
        el.innerHTML = "<span class=\"sketch sketch-a\" aria-hidden=\"true\"></span><span class=\"sketch sketch-b\" aria-hidden=\"true\"></span><span class=\"knot\" aria-hidden=\"true\"></span><span class=\"string\" aria-hidden=\"true\"></span>";
        el.style.setProperty("--size", `${sizeBase.toFixed(2)}px`);
        el.style.setProperty("--rot", rotation);
        el.style.setProperty("--sketch-rot", `${lerp(-2.8, 2.8, random()).toFixed(2)}deg`);
        el.style.setProperty("--jitter-x", `${lerp(-2.5, 2.5, random()).toFixed(2)}px`);
        el.style.setProperty("--jitter-y", `${lerp(-2.2, 2.2, random()).toFixed(2)}px`);
        el.style.setProperty("--radius", `${lerp(42, 51, random()).toFixed(1)}% ${lerp(49, 58, random()).toFixed(1)}% ${lerp(43, 52, random()).toFixed(1)}% ${lerp(47, 56, random()).toFixed(1)}% / ${lerp(41, 49, random()).toFixed(1)}% ${lerp(41, 49, random()).toFixed(1)}% ${lerp(55, 62, random()).toFixed(1)}% ${lerp(52, 60, random()).toFixed(1)}%`);
        el.style.setProperty("--stroke", `${lerp(1.8, 3.3, random()).toFixed(2)}px`);
        el.style.setProperty("--line", tone.line);
        el.style.setProperty("--tone-a", tone.a);
        el.style.setProperty("--tone-b", tone.b);
        el.style.setProperty("--tone-c", tone.c);
        el.style.setProperty("--flat-shade", tone.shade);
        el.style.setProperty("--flat-light", tone.light);
        el.style.setProperty("--grain-a", tone.grainA);
        el.style.setProperty("--grain-b", tone.grainB);
        el.style.setProperty("--angle-a", `${lerp(18, 34, random()).toFixed(1)}deg`);
        el.style.setProperty("--angle-b", `${lerp(88, 116, random()).toFixed(1)}deg`);
        el.style.zIndex = String(20 + index);
        field.appendChild(el);

        return {
          el,
          style: el.style,
          originX,
          originY,
          finalX: cell.x,
          finalY: cell.y,
          appear,
          release,
          duration,
          edge: Boolean(cell.edge),
          sizeBase,
          rotation,
          phase: random() * Math.PI * 2,
          sway: lerp(-1.8, 1.8, random()),
          visible: false,
          lastOpacity: "",
          lastTransform: ""
        };
      });

      let latestProgress = -1;
      let targetProgress = prefersReduced ? 1 : clamp(window.scrollY / getMaxScroll());
      let visualProgress = targetProgress;
      let lastFrameTime = performance.now();
      let scrollSync = false;
      let wheelRemainder = 0;
      let wheelFrame = 0;
      const liveState = {
        story: false,
        interlude: false,
        booking: false
      };

      function setLive(element, key, active) {
        if (liveState[key] === active) {
          return;
        }

        liveState[key] = active;
        element.classList.toggle("is-live", active);
      }

      function render(progress) {
        progress = prefersReduced ? 1 : clamp(progress);
        const pack = smooth(clamp((progress - 0.18) / 0.075));
        const fade = smooth(clamp((progress - 0.295) / 0.055));
        const storyIn = smooth(clamp((progress - 0.325) / 0.105));
        const storyOut = smooth(clamp((progress - 0.53) / 0.07));
        const story = storyIn * (1 - storyOut);
        const interludeIn = smooth(clamp((progress - 0.57) / 0.085));
        const interludeOut = smooth(clamp((progress - 0.72) / 0.07));
        const interlude = interludeIn * (1 - interludeOut);
        const booking = smooth(clamp((progress - 0.79) / 0.115));
        const veil = Math.max(story, interlude, booking);
        const curtain = smooth(clamp((progress - 0.255) / 0.08));
        const mark = 0.055 * smooth(clamp((progress - 0.335) / 0.055)) * (1 - booking);
        root.style.setProperty("--progress", progress.toFixed(5));
        root.style.setProperty("--veil", veil.toFixed(5));
        root.style.setProperty("--story", story.toFixed(5));
        root.style.setProperty("--interlude", interlude.toFixed(5));
        root.style.setProperty("--booking", booking.toFixed(5));
        root.style.setProperty("--mark", mark.toFixed(5));
        setLive(panel, "story", story > 0.82);
        setLive(detailPanel, "interlude", interlude > 0.82);
        setLive(bookingPanel, "booking", booking > 0.82);

        balloons.forEach((balloon) => {
          const inProgress = smooth(clamp((progress - balloon.appear) / 0.07));
          const travel = smooth(clamp((progress - balloon.release) / balloon.duration));
          const micro = Math.sin((progress * 11) + balloon.phase) * balloon.sway * (1 - story * 0.7);
          const baseX = lerp(balloon.originX, balloon.finalX, travel) + micro;
          const baseY = lerp(balloon.originY, balloon.finalY, travel) - curtain * 3 + Math.cos((progress * 8) + balloon.phase) * 1.15;
          const packCenterX = balloon.edge ? (balloon.finalX > 50 ? 58 : 42) : 50;
          const packRatioX = balloon.edge ? 0.96 : 0.84;
          const x = lerp(baseX, packCenterX + ((baseX - packCenterX) * packRatioX), pack);
          const y = lerp(baseY, 50 + ((baseY - 50) * 0.76), pack);
          const scaleIn = lerp(0.18, 1, smooth(clamp((progress - balloon.appear) / 0.18)));
          const closeScale = 1 + (pack * (narrow ? 0.66 : 0.54)) + (fade * 0.12);
          const alpha = inProgress * (1 - fade);
          const opacity = alpha.toFixed(3);

          if (alpha <= 0.003) {
            if (balloon.visible || balloon.lastOpacity !== "0") {
              balloon.style.opacity = "0";
              balloon.visible = false;
              balloon.lastOpacity = "0";
            }
            return;
          }

          const transform = `translate3d(${x.toFixed(3)}vw, ${y.toFixed(3)}vh, 0) translate(-50%, -50%) rotate(${balloon.rotation}) scale(${(scaleIn * closeScale).toFixed(3)})`;
          if (transform !== balloon.lastTransform) {
            balloon.style.transform = transform;
            balloon.lastTransform = transform;
          }
          if (opacity !== balloon.lastOpacity) {
            balloon.style.opacity = opacity;
            balloon.lastOpacity = opacity;
          }
          balloon.visible = true;
        });
      }

      function updateTargetProgress() {
        if (scrollSync) {
          return;
        }

        targetProgress = prefersReduced ? 1 : clamp(window.scrollY / getMaxScroll());
      }

      function setTargetProgress(progress) {
        targetProgress = prefersReduced ? 1 : clamp(progress);

        if (prefersReduced) {
          window.scrollTo({ top: getMaxScroll(), behavior: "auto" });
          return;
        }

        const scrollTop = Math.round(targetProgress * getMaxScroll());
        if (Math.abs(window.scrollY - scrollTop) < 1) {
          return;
        }

        scrollSync = true;
        window.scrollTo({ top: scrollTop, behavior: "auto" });
        window.requestAnimationFrame(() => {
          scrollSync = false;
        });
      }

      function normalizeWheel(event) {
        if (event.deltaMode === 1) {
          return event.deltaY * 32;
        }

        if (event.deltaMode === 2) {
          return event.deltaY * window.innerHeight;
        }

        return event.deltaY;
      }

      function commitWheelStep() {
        wheelFrame = 0;

        const delta = wheelRemainder;
        wheelRemainder = 0;

        if (Math.abs(delta) < 2) {
          return;
        }

        const abs = Math.abs(delta);
        const direction = Math.sign(delta);
        const intensity = abs < 80
          ? clamp(abs / 140, 0.15, 0.58)
          : clamp(abs / 340, 0.72, 1.85);
        const step = (narrow ? 0.094 : 0.084) * intensity * direction;
        setTargetProgress(targetProgress + step);
      }

      function handleWheel(event) {
        if (prefersReduced || event.ctrlKey || Math.abs(event.deltaX) > Math.abs(event.deltaY)) {
          return;
        }

        event.preventDefault();
        wheelRemainder += normalizeWheel(event);

        if (!wheelFrame) {
          wheelFrame = window.requestAnimationFrame(commitWheelStep);
        }
      }

      function handleKeydown(event) {
        if (prefersReduced || event.defaultPrevented || event.altKey || event.ctrlKey || event.metaKey) {
          return;
        }

        const steps = {
          ArrowDown: 0.045,
          ArrowUp: -0.045,
          PageDown: 0.13,
          PageUp: -0.13,
          " ": event.shiftKey ? -0.13 : 0.13,
          Home: -Infinity,
          End: Infinity
        };
        const step = steps[event.key];

        if (step === undefined) {
          return;
        }

        event.preventDefault();
        setTargetProgress(step === Infinity ? 1 : step === -Infinity ? 0 : targetProgress + step);
      }

      function frame(now) {
        updateTargetProgress();

        const elapsed = Math.min(0.08, Math.max(0.001, (now - lastFrameTime) / 1000 || 0.016));
        lastFrameTime = now;

        if (prefersReduced) {
          visualProgress = 1;
        } else {
          const distance = targetProgress - visualProgress;
          const distanceAbs = Math.abs(distance);
          const rate = 8.5 + Math.min(17, distanceAbs * 54);
          const easedStep = 1 - Math.exp(-rate * elapsed);
          const rawStep = distance * easedStep;
          const maxStep = (0.19 + Math.min(0.42, distanceAbs * 1.18)) * elapsed;
          visualProgress += Math.sign(distance) * Math.min(Math.abs(rawStep), maxStep);

          if (Math.abs(targetProgress - visualProgress) < 0.000015) {
            visualProgress = targetProgress;
          }
        }

        if (Math.abs(visualProgress - latestProgress) > 0.00001 || Math.abs(targetProgress - visualProgress) > 0.00001) {
          latestProgress = visualProgress;
          render(visualProgress);
        }
        window.requestAnimationFrame(frame);
      }

      skip.addEventListener("click", () => {
        setTargetProgress(1);
      });

      document.querySelectorAll("[data-page-transition]").forEach((link) => {
        link.addEventListener("click", (event) => {
          if (
            event.defaultPrevented ||
            event.button !== 0 ||
            event.metaKey ||
            event.ctrlKey ||
            event.shiftKey ||
            event.altKey
          ) {
            return;
          }

          const target = link.getAttribute("href");
          if (!target || target.startsWith("#")) {
            return;
          }

          event.preventDefault();
          sessionStorage.setItem("1820PageTransition", "reservation");
          pageTransition.classList.add("is-active");

          window.setTimeout(() => {
            window.location.href = target;
          }, prefersReduced ? 0 : 940);
        });
      });

      window.addEventListener("wheel", handleWheel, { passive: false });
      window.addEventListener("keydown", handleKeydown);
      window.addEventListener("scroll", updateTargetProgress, { passive: true });

      window.addEventListener("resize", () => {
        narrow = isNarrow();
        updateTargetProgress();
        latestProgress = -1;
      });

      frame();
    })();
  </script>
</body>
</html>

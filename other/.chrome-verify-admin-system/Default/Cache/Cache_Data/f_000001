<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>1820 | Admin</title>
  <style>
    :root {
      --paper: #f3f3f3;
      --ink: #070707;
      --graphite: #2d2d2d;
      --muted: #686868;
      --soft: #cfcfcf;
      --line: rgba(0, 0, 0, 0.25);
      --hard: #080808;
      --panel: rgba(244, 244, 244, 0.9);
      --success: #111111;
      --warn: #555555;
    }

    * {
      box-sizing: border-box;
    }

    html {
      min-height: 100%;
      background: var(--paper);
      color: var(--ink);
    }

    body {
      min-height: 100vh;
      margin: 0;
      overflow-x: hidden;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      letter-spacing: 0;
      background:
        repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.025) 0 1px, transparent 1px 8px),
        linear-gradient(180deg, #f6f6f6 0%, #eeeeee 45%, #dadada 100%);
    }

    body::before {
      content: "1820";
      position: fixed;
      inset: 0;
      z-index: 0;
      display: grid;
      place-items: center;
      pointer-events: none;
      color: #080808;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(8rem, 22vw, 24rem);
      font-weight: 400;
      line-height: 0.76;
      opacity: 0.045;
      transform: translateY(-1vh);
    }

    body::after {
      content: "";
      position: fixed;
      inset: 0;
      z-index: 80;
      pointer-events: none;
      opacity: 0.22;
      background:
        repeating-radial-gradient(circle at 24% 34%, rgba(0, 0, 0, 0.08) 0 1px, transparent 1px 5px),
        repeating-linear-gradient(112deg, rgba(0, 0, 0, 0.03) 0 1px, transparent 1px 7px);
      mix-blend-mode: multiply;
    }

    a,
    button,
    input,
    select,
    textarea {
      color: inherit;
      font: inherit;
      -webkit-tap-highlight-color: transparent;
    }

    a {
      text-decoration: none;
    }

    button {
      cursor: pointer;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 70;
      min-height: 68px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      padding: 18px clamp(16px, 3vw, 42px);
      border-bottom: 1px solid rgba(0, 0, 0, 0.2);
      background:
        repeating-linear-gradient(112deg, rgba(0, 0, 0, 0.035) 0 1px, transparent 1px 5px),
        rgba(244, 244, 244, 0.94);
      backdrop-filter: blur(12px);
    }

    .brand,
    .label,
    .button,
    .chip,
    .metric-label,
    .table th,
    .field label,
    .tiny {
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .brand {
      font-size: clamp(1rem, 0.86rem + 0.56vw, 1.4rem);
      letter-spacing: 0.02em;
    }

    .top-actions {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 10px;
      flex-wrap: wrap;
    }

    .admin-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1760px);
      margin: 0 auto;
      padding: clamp(18px, 3vw, 42px);
      display: grid;
      gap: 18px;
    }

    .hero-row {
      display: grid;
      grid-template-columns: minmax(320px, 0.72fr) minmax(520px, 1.28fr);
      gap: 18px;
      align-items: stretch;
    }

    .title-panel,
    .control-panel,
    .panel,
    .metric,
    .reservation-card,
    .note-item,
    .seat,
    .table-seat {
      border: 1px solid var(--line);
      background:
        repeating-linear-gradient(112deg, rgba(0, 0, 0, 0.032) 0 1px, transparent 1px 5px),
        var(--panel);
    }

    .title-panel,
    .control-panel,
    .panel {
      box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.88);
    }

    .title-panel {
      padding: clamp(22px, 3vw, 36px);
      display: grid;
      align-content: end;
      min-height: 260px;
    }

    .kicker {
      margin: 0 0 18px;
      color: #4e4e4e;
    }

    h1,
    h2,
    h3 {
      margin: 0;
      letter-spacing: 0;
    }

    h1 {
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(4.5rem, 10vw, 11rem);
      font-weight: 400;
      line-height: 0.82;
    }

    h2 {
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.3rem, 4vw, 4.8rem);
      font-weight: 400;
      line-height: 0.92;
    }

    h3 {
      font-size: 0.96rem;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .control-panel {
      padding: clamp(18px, 2.4vw, 30px);
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      align-content: start;
    }

    .field {
      display: grid;
      gap: 8px;
      min-width: 0;
    }

    .field.is-wide {
      grid-column: 1 / -1;
    }

    input,
    select,
    textarea {
      width: 100%;
      min-height: 48px;
      border: 1px solid rgba(0, 0, 0, 0.34);
      border-radius: 0;
      background:
        repeating-linear-gradient(112deg, rgba(0, 0, 0, 0.025) 0 1px, transparent 1px 5px),
        #f7f7f7;
      color: #080808;
      padding: 0 12px;
      outline: none;
      font-size: 0.94rem;
      font-weight: 650;
      transition: border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }

    textarea {
      min-height: 92px;
      padding: 12px;
      resize: vertical;
      line-height: 1.45;
    }

    input:focus,
    select:focus,
    textarea:focus {
      border-color: #080808;
      box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.16);
      background: #ffffff;
    }

    .button-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: end;
    }

    .button {
      min-height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: 2px solid #080808;
      border-radius: 0;
      padding: 13px 16px;
      background: #080808;
      color: #f5f5f5;
      box-shadow: 5px 5px 0 rgba(0, 0, 0, 0.16);
      transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease, color 180ms ease;
    }

    .button.is-secondary {
      background: #f4f4f4;
      color: #080808;
    }

    .button.is-quiet {
      border-color: rgba(0, 0, 0, 0.28);
      background: rgba(255, 255, 255, 0.45);
      color: #080808;
      box-shadow: none;
    }

    .button:hover,
    .button:focus-visible {
      transform: translate(2px, 2px);
      box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.2);
      outline: none;
    }

    .button.is-quiet:hover,
    .button.is-quiet:focus-visible {
      box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.12);
    }

    .metric-grid {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 12px;
    }

    .metric {
      min-height: 112px;
      padding: 16px;
      display: grid;
      align-content: space-between;
      gap: 14px;
    }

    .metric-value {
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.4rem, 4vw, 4.2rem);
      line-height: 0.82;
    }

    .metric-label {
      color: #555555;
    }

    .main-grid {
      display: grid;
      grid-template-columns: minmax(560px, 1.2fr) minmax(420px, 0.8fr);
      gap: 18px;
      align-items: start;
    }

    .panel {
      min-width: 0;
    }

    .panel-head {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 16px;
      padding: 18px;
      border-bottom: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.36);
    }

    .panel-body {
      padding: 18px;
    }

    .panel-tools {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 8px;
      flex-wrap: wrap;
    }

    .chip {
      min-height: 32px;
      display: inline-flex;
      align-items: center;
      border: 1px solid rgba(0, 0, 0, 0.24);
      padding: 7px 9px;
      color: #666666;
      background: rgba(255, 255, 255, 0.4);
    }

    .chip.is-dark {
      color: #f5f5f5;
      border-color: #080808;
      background: #080808;
    }

    .timetable {
      max-height: 680px;
      overflow: auto;
      border: 1px solid rgba(0, 0, 0, 0.18);
      background: rgba(255, 255, 255, 0.32);
      scrollbar-color: #080808 rgba(0, 0, 0, 0.12);
      scrollbar-width: thin;
    }

    .time-row {
      display: grid;
      grid-template-columns: 76px 140px 140px minmax(260px, 1fr);
      min-height: 64px;
      border-bottom: 1px solid rgba(0, 0, 0, 0.13);
    }

    .time-row:last-child {
      border-bottom: 0;
    }

    .time-cell,
    .load-cell,
    .starts-cell {
      padding: 12px;
      border-right: 1px solid rgba(0, 0, 0, 0.13);
    }

    .starts-cell {
      border-right: 0;
      display: grid;
      gap: 8px;
    }

    .time-cell {
      font-weight: 900;
      font-size: 0.88rem;
    }

    .load-cell {
      display: grid;
      gap: 7px;
      align-content: center;
    }

    .load-text {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      color: #1a1a1a;
      font-size: 0.78rem;
      font-weight: 850;
    }

    .load-bar {
      height: 7px;
      border: 1px solid rgba(0, 0, 0, 0.2);
      background: rgba(255, 255, 255, 0.54);
      overflow: hidden;
    }

    .load-bar span {
      display: block;
      height: 100%;
      width: var(--load, 0%);
      background: #080808;
    }

    .reservation-card {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 8px 12px;
      padding: 10px;
      cursor: pointer;
      transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    }

    .reservation-card:hover,
    .reservation-card:focus-visible,
    .reservation-card.is-selected {
      transform: translateY(-1px);
      box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.16);
      outline: none;
      background: #ffffff;
    }

    .reservation-name {
      min-width: 0;
      font-size: 0.92rem;
      font-weight: 900;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .reservation-meta {
      color: #4a4a4a;
      font-size: 0.78rem;
      font-weight: 740;
    }

    .status {
      align-self: start;
      border: 1px solid rgba(0, 0, 0, 0.24);
      padding: 5px 7px;
      background: #f7f7f7;
      font-size: 0.66rem;
      font-weight: 950;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .status.confirmed,
    .status.seated {
      background: #080808;
      color: #f5f5f5;
    }

    .status.cancelled,
    .status.no_show {
      color: #5f5f5f;
      background: #dedede;
    }

    .editor-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .resource-grid {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 8px;
    }

    .resource-choice {
      min-height: 42px;
      display: grid;
      place-items: center;
      border: 1px solid rgba(0, 0, 0, 0.28);
      background: #f7f7f7;
      font-size: 0.78rem;
      font-weight: 900;
      cursor: pointer;
      transition: background 160ms ease, color 160ms ease, opacity 160ms ease;
    }

    .resource-choice input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .resource-choice:has(input:checked) {
      background: #080808;
      color: #f5f5f5;
    }

    .resource-choice.is-busy {
      opacity: 0.36;
      cursor: not-allowed;
    }

    .message {
      display: none;
      padding: 12px;
      border: 1px solid rgba(0, 0, 0, 0.28);
      background: #080808;
      color: #f5f5f5;
      font-size: 0.86rem;
      font-weight: 760;
      line-height: 1.4;
    }

    .message.is-visible {
      display: block;
    }

    .floor-grid {
      display: grid;
      grid-template-columns: minmax(280px, 0.44fr) minmax(0, 1fr);
      gap: 16px;
    }

    .bar-map {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 8px;
    }

    .table-map {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .seat,
    .table-seat {
      min-height: 58px;
      padding: 10px;
      display: grid;
      align-content: space-between;
      gap: 6px;
    }

    .table-seat {
      min-height: 112px;
    }

    .seat.is-busy,
    .table-seat.is-busy {
      background:
        repeating-linear-gradient(112deg, rgba(255, 255, 255, 0.055) 0 1px, transparent 1px 5px),
        #151515;
      color: #f5f5f5;
      border-color: #080808;
    }

    .seat-title {
      font-size: 0.84rem;
      font-weight: 950;
    }

    .seat-detail {
      color: inherit;
      opacity: 0.76;
      font-size: 0.76rem;
      font-weight: 760;
      line-height: 1.3;
    }

    .client-grid {
      display: grid;
      grid-template-columns: minmax(280px, 0.44fr) minmax(0, 1fr);
      gap: 16px;
    }

    .client-list,
    .note-list {
      display: grid;
      gap: 8px;
      max-height: 390px;
      overflow: auto;
      padding-right: 4px;
    }

    .client-button {
      width: 100%;
      border: 1px solid rgba(0, 0, 0, 0.24);
      background: rgba(255, 255, 255, 0.42);
      padding: 12px;
      text-align: left;
      display: grid;
      gap: 5px;
    }

    .client-button.is-selected {
      background: #080808;
      color: #f5f5f5;
    }

    .client-name {
      font-size: 0.92rem;
      font-weight: 900;
    }

    .client-sub {
      opacity: 0.72;
      font-size: 0.78rem;
      font-weight: 720;
    }

    .note-item {
      padding: 12px;
      display: grid;
      gap: 8px;
    }

    .note-meta {
      color: #555555;
      font-size: 0.72rem;
      font-weight: 850;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .note-text {
      margin: 0;
      font-size: 0.9rem;
      font-weight: 650;
      line-height: 1.45;
    }

    .table-wrap {
      overflow: auto;
      border: 1px solid rgba(0, 0, 0, 0.18);
      background: rgba(255, 255, 255, 0.32);
    }

    .table {
      width: 100%;
      min-width: 1040px;
      border-collapse: collapse;
    }

    .table th,
    .table td {
      padding: 12px;
      border-bottom: 1px solid rgba(0, 0, 0, 0.15);
      text-align: left;
      vertical-align: top;
    }

    .table tr {
      cursor: pointer;
    }

    .table tr:hover,
    .table tr.is-selected {
      background: rgba(255, 255, 255, 0.7);
    }

    .table td {
      font-size: 0.88rem;
      font-weight: 650;
      line-height: 1.35;
    }

    .backend-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }

    .schema-line {
      border: 1px solid rgba(0, 0, 0, 0.22);
      background: rgba(255, 255, 255, 0.4);
      padding: 12px;
      display: grid;
      gap: 8px;
    }

    .schema-line code {
      font-size: 0.84rem;
      font-weight: 720;
      word-break: break-word;
    }

    .empty {
      color: #555555;
      font-size: 0.9rem;
      font-weight: 700;
      line-height: 1.45;
      padding: 10px 0;
    }

    @media (max-width: 1180px) {
      .hero-row,
      .main-grid,
      .floor-grid,
      .client-grid {
        grid-template-columns: 1fr;
      }

      .metric-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .control-panel {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 720px) {
      .admin-shell {
        padding: 14px;
      }

      .topbar,
      .top-actions,
      .panel-head,
      .button-row {
        align-items: stretch;
        flex-direction: column;
      }

      .title-panel {
        min-height: auto;
      }

      h1 {
        font-size: clamp(4.4rem, 22vw, 7.2rem);
      }

      .control-panel,
      .metric-grid,
      .editor-grid,
      .backend-grid {
        grid-template-columns: 1fr;
      }

      .time-row {
        grid-template-columns: 64px minmax(0, 1fr);
      }

      .load-cell {
        display: none;
      }

      .time-cell {
        border-right: 1px solid rgba(0, 0, 0, 0.13);
      }

      .resource-grid,
      .bar-map,
      .table-map {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <a class="brand" href="../index.html">1820</a>
    <div class="top-actions">
      <span class="chip is-dark" id="connectionChip">Local database</span>
      <a class="button is-quiet" href="login.html">Access</a>
    </div>
  </header>

  <main class="admin-shell">
    <section class="hero-row">
      <div class="title-panel">
        <p class="label kicker">Booking control system</p>
        <h1>Admin room.</h1>
      </div>

      <div class="control-panel" aria-label="Admin controls">
        <div class="field">
          <label for="adminDate">Service date</label>
          <input id="adminDate" type="date" />
        </div>
        <div class="field">
          <label for="statusFilter">Status</label>
          <select id="statusFilter">
            <option value="all">All statuses</option>
            <option value="confirmed">Confirmed</option>
            <option value="seated">Seated</option>
            <option value="completed">Completed</option>
            <option value="waitlist">Waitlist</option>
            <option value="cancelled">Cancelled</option>
            <option value="no_show">No show</option>
          </select>
        </div>
        <div class="field">
          <label for="searchInput">Search</label>
          <input id="searchInput" type="search" placeholder="Name, phone, email, note" />
        </div>
        <div class="field">
          <label for="serverFilter">Server</label>
          <select id="serverFilter">
            <option value="all">All servers</option>
          </select>
        </div>
        <div class="field is-wide">
          <label>Controls</label>
          <div class="button-row">
            <button class="button" id="newReservationButton" type="button">New booking</button>
            <button class="button is-secondary" id="importPublicButton" type="button">Import public saves</button>
            <button class="button is-secondary" id="exportButton" type="button">Export JSON</button>
            <button class="button is-quiet" id="resetDemoButton" type="button">Reset demo</button>
          </div>
        </div>
      </div>
    </section>

    <section class="metric-grid" aria-label="Service metrics">
      <div class="metric">
        <span class="metric-label">Bookings</span>
        <span class="metric-value" id="metricBookings">0</span>
      </div>
      <div class="metric">
        <span class="metric-label">Covers</span>
        <span class="metric-value" id="metricCovers">0</span>
      </div>
      <div class="metric">
        <span class="metric-label">Table peak</span>
        <span class="metric-value" id="metricTablePeak">0/12</span>
      </div>
      <div class="metric">
        <span class="metric-label">Bar peak</span>
        <span class="metric-value" id="metricBarPeak">0/12</span>
      </div>
      <div class="metric">
        <span class="metric-label">Returning</span>
        <span class="metric-value" id="metricReturning">0</span>
      </div>
      <div class="metric">
        <span class="metric-label">Open issues</span>
        <span class="metric-value" id="metricIssues">0</span>
      </div>
    </section>

    <section class="main-grid">
      <section class="panel" aria-label="Timetable">
        <div class="panel-head">
          <div>
            <h2>Timetable.</h2>
            <span class="tiny" id="timetableDateLabel">Service day</span>
          </div>
          <div class="panel-tools">
            <span class="chip">Tables max 12</span>
            <span class="chip">Bar spaces 12</span>
          </div>
        </div>
        <div class="panel-body">
          <div class="timetable" id="timetable"></div>
        </div>
      </section>

      <section class="panel" aria-label="Reservation editor">
        <div class="panel-head">
          <div>
            <h2>Booking.</h2>
            <span class="tiny" id="editorModeLabel">Editing</span>
          </div>
          <div class="panel-tools">
            <button class="button is-quiet" id="duplicateButton" type="button">Duplicate</button>
          </div>
        </div>
        <div class="panel-body">
          <div class="message" id="editorMessage"></div>
          <form id="reservationEditor" class="editor-grid">
            <input id="reservationId" type="hidden" />
            <div class="field is-wide">
              <label for="customerSelect">Client</label>
              <select id="customerSelect"></select>
            </div>
            <div class="field">
              <label for="bookingDate">Date</label>
              <input id="bookingDate" type="date" />
            </div>
            <div class="field">
              <label for="bookingTime">Time</label>
              <select id="bookingTime"></select>
            </div>
            <div class="field">
              <label for="durationMinutes">Duration</label>
              <select id="durationMinutes">

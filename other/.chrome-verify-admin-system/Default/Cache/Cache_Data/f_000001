        dom.statusFilter.value = state.status;
        dom.searchInput.value = state.search;
        dom.serverFilter.innerHTML = `<option value="all">All servers</option>${SERVERS.map((server) => `<option value="${server}">${server}</option>`).join("")}`;
        dom.serverFilter.value = state.server;
        dom.connectionChip.textContent = AdminBackend.mode === "localStorage" ? "Local database" : "Remote ready";
        dom.backendMode.textContent = AdminBackend.mode;
      }

      function renderMetrics() {
        const dayReservations = reservationsForDate();
        const active = dayReservations.filter(isActive);
        const covers = active.reduce((sum, reservation) => sum + Number(reservation.guests || 0), 0);
        let tablePeak = 0;
        let barPeak = 0;
        TIME_SLOTS.forEach((slot) => {
          const load = occupancyAt(state.selectedDate, slot);
          tablePeak = Math.max(tablePeak, load.tableCovers);
          barPeak = Math.max(barPeak, load.barCovers);
        });
        const returning = new Set(active.filter((reservation) => visitsForCustomer(reservation.customerId).length > 1).map((reservation) => reservation.customerId)).size;
        const issues = active.filter((reservation) => validateReservation(reservation, reservation.id).length > 0).length;
        dom.metricBookings.textContent = String(dayReservations.length);
        dom.metricCovers.textContent = String(covers);
        dom.metricTablePeak.textContent = `${tablePeak}/12`;
        dom.metricBarPeak.textContent = `${barPeak}/12`;
        dom.metricReturning.textContent = String(returning);
        dom.metricIssues.textContent = String(issues);
      }

      function renderTimetable() {
        dom.timetableDateLabel.textContent = formatDate(state.selectedDate);
        dom.timetable.innerHTML = TIME_SLOTS.map((slot) => {
          const load = occupancyAt(state.selectedDate, slot);
          const starts = reservationsForDate().filter((reservation) => reservation.time === slot);
          return `
            <div class="time-row">
              <div class="time-cell">${slot}</div>
              <div class="load-cell">
                <div class="load-text"><span>Tables</span><span>${load.tableCovers}/12</span></div>
                <div class="load-bar" style="--load:${Math.min(100, (load.tableCovers / 12) * 100)}%"><span></span></div>
              </div>
              <div class="load-cell">
                <div class="load-text"><span>Bar</span><span>${load.barCovers}/12</span></div>
                <div class="load-bar" style="--load:${Math.min(100, (load.barCovers / 12) * 100)}%"><span></span></div>
              </div>
              <div class="starts-cell">${starts.length ? starts.map(renderReservationCard).join("") : `<span class="empty">Open</span>`}</div>
            </div>
          `;
        }).join("");
        $$(".reservation-card", dom.timetable).forEach((card) => {
          card.addEventListener("click", () => selectReservation(card.dataset.id));
          card.addEventListener("keydown", (event) => {
            if (event.key === "Enter") {
              selectReservation(card.dataset.id);
            }
          });
        });
      }

      function renderReservationCard(reservation) {
        const customer = getCustomer(reservation.customerId);
        return `
          <button class="reservation-card ${state.selectedReservationId === reservation.id ? "is-selected" : ""}" data-id="${reservation.id}" type="button">
            <span>
              <span class="reservation-name">${escapeHtml(customer?.name || "Unknown client")}</span>
              <span class="reservation-meta">${reservation.guests} guests / ${seatingLabel(reservation.seatingType)} / ${resourcesLabel(reservation)}</span>
            </span>
            <span class="status ${reservation.status}">${statusLabel(reservation.status)}</span>
          </button>
        `;
      }

      function renderReservationTable() {
        const rows = matchingReservations();
        dom.databaseCountLabel.textContent = `${rows.length} reservations`;
        dom.reservationRows.innerHTML = rows.map((reservation) => {
          const customer = getCustomer(reservation.customerId);
          return `
            <tr data-id="${reservation.id}" class="${state.selectedReservationId === reservation.id ? "is-selected" : ""}">
              <td>${reservation.time}<br><span class="tiny">${reservation.durationMinutes}m</span></td>
              <td>${escapeHtml(customer?.name || "Unknown")}<br><span class="tiny">${visitsForCustomer(reservation.customerId).length} visits</span></td>
              <td>${escapeHtml(customer?.phone || "")}<br>${escapeHtml(customer?.email || "")}</td>
              <td>${reservation.guests}</td>
              <td>${seatingLabel(reservation.seatingType)}</td>
              <td>${escapeHtml(resourcesLabel(reservation))}</td>
              <td><span class="status ${reservation.status}">${statusLabel(reservation.status)}</span></td>
              <td>${escapeHtml(reservation.internalNote || reservation.requests || "")}</td>
            </tr>
          `;
        }).join("") || `<tr><td colspan="8">No reservations match this view.</td></tr>`;
        $$("tr[data-id]", dom.reservationRows).forEach((row) => {
          row.addEventListener("click", () => selectReservation(row.dataset.id));
        });
      }

      function renderEditor() {
        renderSelects();
        const reservation = getReservation(state.selectedReservationId) || draftReservation();
        dom.editorModeLabel.textContent = reservation.id ? `Editing ${reservation.id}` : "New booking";
        dom.reservationId.value = reservation.id || "";
        dom.customerSelect.value = reservation.customerId || state.selectedCustomerId || state.data.customers[0]?.id || "";
        dom.bookingDate.value = reservation.date || state.selectedDate;
        dom.bookingTime.value = reservation.time || "18:00";
        dom.durationMinutes.value = String(reservation.durationMinutes || 120);
        dom.bookingStatus.value = reservation.status || "confirmed";
        dom.guestCount.value = String(reservation.guests || 2);
        dom.seatingType.value = reservation.seatingType || "table";
        dom.serverName.value = reservation.server || SERVERS[0];
        dom.bookingSource.value = reservation.source || "admin";
        dom.guestRequests.value = reservation.requests || "";
        dom.internalNote.value = reservation.internalNote || "";
        renderResourceChoices(reservation);
        toggleResourceWraps();
      }

      function renderSelects() {
        dom.customerSelect.innerHTML = state.data.customers
          .slice()
          .sort((a, b) => a.name.localeCompare(b.name))
          .map((customer) => `<option value="${customer.id}">${escapeHtml(customer.name)} / ${escapeHtml(customer.phone)}</option>`)
          .join("");
        dom.bookingTime.innerHTML = TIME_SLOTS.map((slot) => `<option value="${slot}">${slot}</option>`).join("");
        dom.serverName.innerHTML = SERVERS.map((server) => `<option value="${server}">${server}</option>`).join("");
      }

      function renderResourceChoices(reservation) {
        const candidate = readEditor({ fallback: reservation });
        const busy = busyResources(candidate, reservation.id);
        dom.tableResourceChoices.innerHTML = TABLES.map((table) => {
          const checked = (reservation.assignedTables || []).includes(table.id);
          const busyName = busy.tables.get(table.id);
          return `
            <label class="resource-choice ${busyName ? "is-busy" : ""}" title="${busyName ? `Busy: ${busyName}` : `${table.capacity} seats`}">
              <input type="checkbox" name="tables" value="${table.id}" ${checked ? "checked" : ""} ${busyName ? "disabled" : ""} />
              ${table.id}
            </label>
          `;
        }).join("");
        dom.barResourceChoices.innerHTML = BAR_SEATS.map((seat) => {
          const checked = (reservation.assignedBarSeats || []).includes(seat);
          const busyName = busy.bars.get(seat);
          return `
            <label class="resource-choice ${busyName ? "is-busy" : ""}" title="${busyName ? `Busy: ${busyName}` : "Open"}">
              <input type="checkbox" name="barSeats" value="${seat}" ${checked ? "checked" : ""} ${busyName ? "disabled" : ""} />
              ${seat}
            </label>
          `;
        }).join("");
      }

      function renderFloor() {
        const candidate = readEditor({ fallback: getReservation(state.selectedReservationId) || draftReservation() });
        const busy = busyResources(candidate, candidate.id || "");
        dom.floorContext.textContent = `${formatDate(candidate.date)} / ${candidate.time} / ${candidate.durationMinutes}m`;
        dom.barMap.innerHTML = BAR_SEATS.map((seat) => {
          const owner = busy.bars.get(seat);
          const selected = (candidate.assignedBarSeats || []).includes(seat);
          return `
            <div class="seat ${owner || selected ? "is-busy" : ""}">
              <span class="seat-title">${seat}</span>
              <span class="seat-detail">${selected ? "Selected" : owner || "Open"}</span>
            </div>
          `;
        }).join("");
        dom.tableMap.innerHTML = TABLES.map((table) => {
          const owner = busy.tables.get(table.id);
          const selected = (candidate.assignedTables || []).includes(table.id);
          return `
            <div class="table-seat ${owner || selected ? "is-busy" : ""}">
              <span class="seat-title">${table.id}</span>
              <span class="seat-detail">4 seats</span>
              <span class="seat-detail">${selected ? "Selected" : owner || "Open"}</span>
            </div>
          `;
        }).join("");
      }

      function renderClients() {
        const ordered = state.data.customers.slice().sort((a, b) => {
          const visitsA = visitsForCustomer(a.id).length;
          const visitsB = visitsForCustomer(b.id).length;
          return visitsB - visitsA || a.name.localeCompare(b.name);
        });
        dom.clientCountLabel.textContent = `${ordered.length} profiles`;
        dom.clientList.innerHTML = ordered.map((customer) => {
          const visits = visitsForCustomer(customer.id);
          return `
            <button class="client-button ${state.selectedCustomerId === customer.id ? "is-selected" : ""}" data-id="${customer.id}" type="button">
              <span class="client-name">${escapeHtml(customer.name)}</span>
              <span class="client-sub">${visits.length} visits / ${escapeHtml(customer.phone)}</span>
            </button>
          `;
        }).join("");
        $$(".client-button", dom.clientList).forEach((button) => {
          button.addEventListener("click", () => selectCustomer(button.dataset.id));
        });
        renderClientDetail();
      }

      function renderClientDetail() {
        const customer = getCustomer(state.selectedCustomerId) || getCustomer(getReservation(state.selectedReservationId)?.customerId) || state.data.customers[0];
        if (!customer) {
          dom.clientProfile.innerHTML = `<p class="empty">No client selected.</p>`;
          dom.clientNotes.innerHTML = "";
          return;
        }
        state.selectedCustomerId = customer.id;
        const visits = visitsForCustomer(customer.id);
        const last = visits[0];
        dom.clientProfile.innerHTML = `
          <div class="schema-line"><span class="label">Name</span><code>${escapeHtml(customer.name)}</code></div>
          <div class="schema-line"><span class="label">Phone</span><code>${escapeHtml(customer.phone)}</code></div>
          <div class="schema-line"><span class="label">Email</span><code>${escapeHtml(customer.email)}</code></div>
          <div class="schema-line"><span class="label">Tags</span><code>${escapeHtml((customer.tags || []).join(", ") || "None")}</code></div>
          <div class="schema-line"><span class="label">Last booking</span><code>${last ? `${formatDate(last.date)} ${last.time} / ${last.guests} guests` : "None"}</code></div>
          <div class="schema-line"><span class="label">Profile note</span><code>${escapeHtml(customer.profileNote || "None")}</code></div>
        `;
        const notes = notesForCustomer(customer.id);
        dom.clientNotes.innerHTML = notes.map((item) => `
          <div class="note-item">
            <span class="note-meta">${escapeHtml(item.author)} / ${new Date(item.createdAt).toLocaleString()}</span>
            <p class="note-text">${escapeHtml(item.text)}</p>
          </div>
        `).join("") || `<p class="empty">No notes yet.</p>`;
      }

      function renderBackend() {
        dom.reservationEndpoint.textContent = endpoints.reservations;
        dom.customerEndpoint.textContent = endpoints.customers;
        dom.noteEndpoint.textContent = endpoints.notes;
        dom.storageKeyLabel.textContent = STORAGE_KEY;
      }

      function draftReservation() {
        return {
          id: "",
          customerId: state.selectedCustomerId || state.data.customers[0]?.id || "",
          date: state.selectedDate,
          time: "18:00",
          durationMinutes: 120,
          guests: 2,
          seatingType: "table",
          assignedTables: [],
          assignedBarSeats: [],
          status: "confirmed",
          server: SERVERS[0],
          source: "admin",
          requests: "",
          internalNote: ""
        };
      }

      function readEditor(options = {}) {
        const fallback = options.fallback || {};
        const seatingType = dom.seatingType?.value || fallback.seatingType || "table";
        const assignedTables = options.fallback
          ? [...(fallback.assignedTables || [])]
          : $$("input[name='tables']:checked", dom.tableResourceChoices).map((input) => input.value);
        const assignedBarSeats = options.fallback
          ? [...(fallback.assignedBarSeats || [])]
          : $$("input[name='barSeats']:checked", dom.barResourceChoices).map((input) => input.value);
        return {
          id: dom.reservationId?.value || fallback.id || "",
          customerId: dom.customerSelect?.value || fallback.customerId || "",
          date: dom.bookingDate?.value || fallback.date || state.selectedDate,
          time: dom.bookingTime?.value || fallback.time || "18:00",
          durationMinutes: Number(dom.durationMinutes?.value || fallback.durationMinutes || 120),
          status: dom.bookingStatus?.value || fallback.status || "confirmed",
          guests: Number(dom.guestCount?.value || fallback.guests || 1),
          seatingType,
          server: dom.serverName?.value || fallback.server || SERVERS[0],
          source: dom.bookingSource?.value || fallback.source || "admin",
          requests: dom.guestRequests?.value.trim() || fallback.requests || "",
          internalNote: dom.internalNote?.value.trim() || fallback.internalNote || "",
          assignedTables,
          assignedBarSeats,
          createdAt: fallback.createdAt || new Date().toISOString(),
          updatedAt: new Date().toISOString()
        };
      }

      async function saveEditor(event) {
        event?.preventDefault();
        let candidate = readEditor();
        if (candidate.seatingType === "table") {
          candidate.assignedBarSeats = [];
        } else {
          candidate.assignedTables = [];
        }
        if (!candidate.assignedTables.length && !candidate.assignedBarSeats.length) {
          candidate = autoAssign(candidate, candidate.id);
        }
        const issues = validateReservation(candidate, candidate.id);
        if (issues.length) {
          showMessage(issues.join(" "));
          renderResourceChoices(candidate);
          renderFloor();
          return;
        }
        if (!candidate.id) {
          candidate.id = uid("r");
          state.data.reservations.push(candidate);
        } else {
          const index = state.data.reservations.findIndex((reservation) => reservation.id === candidate.id);
          if (index >= 0) {
            state.data.reservations[index] = candidate;
          } else {
            state.data.reservations.push(candidate);
          }
        }
        const customer = getCustomer(candidate.customerId);
        if (customer) {
          customer.updatedAt = new Date().toISOString();
        }
        state.selectedReservationId = candidate.id;
        state.selectedCustomerId = candidate.customerId;
        state.selectedDate = candidate.date;
        await AdminBackend.save(state.data);
        showMessage("Booking saved.", true);
        renderAll();
      }

      function showMessage(message, soft = false) {
        dom.editorMessage.textContent = message;
        dom.editorMessage.classList.add("is-visible");
        dom.editorMessage.style.background = soft ? "#f7f7f7" : "#080808";
        dom.editorMessage.style.color = soft ? "#080808" : "#f5f5f5";
        window.setTimeout(() => dom.editorMessage.classList.remove("is-visible"), 3000);
      }

      function selectReservation(id) {
        const reservation = getReservation(id);
        if (!reservation) {
          return;
        }
        state.selectedReservationId = id;
        state.selectedCustomerId = reservation.customerId;
        state.selectedDate = reservation.date;
        renderAll();
      }

      function selectCustomer(id) {
        state.selectedCustomerId = id;
        const nextReservation = reservationsForDate().find((reservation) => reservation.customerId === id);
        if (nextReservation) {
          state.selectedReservationId = nextReservation.id;
        }
        renderAll();
      }

      function visitsForCustomer(customerId) {
        return state.data.reservations
          .filter((reservation) => reservation.customerId === customerId)
          .sort((a, b) => `${b.date} ${b.time}`.localeCompare(`${a.date} ${a.time}`));
      }

      function notesForCustomer(customerId) {
        return state.data.notes
          .filter((note) => note.customerId === customerId)
          .sort((a, b) => b.createdAt.localeCompare(a.createdAt));
      }

      async function addClientNote() {
        const text = dom.clientNoteText.value.trim();
        if (!text || !state.selectedCustomerId) {
          return;
        }
        state.data.notes.push({
          id: uid("n"),
          customerId: state.selectedCustomerId,
          author: dom.serverName.value || "Admin",
          text,
          createdAt: new Date().toISOString()
        });
        dom.clientNoteText.value = "";
        await AdminBackend.save(state.data);
        renderClients();
      }

      async function cancelSelected() {
        const reservation = getReservation(state.selectedReservationId);
        if (!reservation) {
          return;
        }
        reservation.status = "cancelled";
        reservation.updatedAt = new Date().toISOString();
        await AdminBackend.save(state.data);
        renderAll();
      }

      function duplicateSelected() {
        const reservation = getReservation(state.selectedReservationId);
        if (!reservation) {
          return;
        }
        const copy = {
          ...reservation,
          id: "",
          date: addDays(reservation.date, 1),
          assignedTables: [],
          assignedBarSeats: [],
          status: "confirmed",
          source: "admin",
          internalNote: `${reservation.internalNote || ""} Duplicated from ${reservation.id}.`.trim()
        };
        state.selectedReservationId = "";
        state.selectedCustomerId = copy.customerId;
        state.selectedDate = copy.date;
        renderAll();
        dom.customerSelect.value = copy.customerId;
        dom.bookingDate.value = copy.date;
        dom.bookingTime.value = copy.time;
        dom.durationMinutes.value = String(copy.durationMinutes);
        dom.bookingStatus.value = copy.status;
        dom.guestCount.value = String(copy.guests);
        dom.seatingType.value = copy.seatingType;
        dom.serverName.value = copy.server;
        dom.bookingSource.value = copy.source;
        dom.guestRequests.value = copy.requests;
        dom.internalNote.value = copy.internalNote;
        renderResourceChoices(copy);
        renderFloor();
      }

      function applyAutoSeat() {
        const candidate = autoAssign(readEditor(), dom.reservationId.value);
        renderResourceChoices(candidate);
        candidate.assignedTables.forEach((id) => {
          const input = $(`input[name='tables'][value='${id}']`, dom.tableResourceChoices);
          if (input) input.checked = true;
        });
        candidate.assignedBarSeats.forEach((id) => {
          const input = $(`input[name='barSeats'][value='${id}']`, dom.barResourceChoices);
          if (input) input.checked = true;
        });
        renderFloor();
      }

      async function importPublicReservations() {
        const raw = localStorage.getItem(PUBLIC_RECORDS_KEY);
        if (!raw) {
          showMessage("No public reservation records found.");
          return;
        }
        const records = JSON.parse(raw);
        let imported = 0;
        records.forEach((record) => {
          const marker = `${record.email || ""}|${record.booking_date || ""}|${record.booking_time || ""}|${record.created_at || ""}`;
          const exists = state.data.reservations.some((reservation) => reservation.publicMarker === marker);
          if (exists) {
            return;
          }
          let customer = state.data.customers.find((item) => item.email && item.email === record.email);
          if (!customer) {
            customer = customerFromPublic(record);
            state.data.customers.push(customer);
          }
          let reservation = {
            id: uid("r"),
            publicMarker: marker,
            customerId: customer.id,
            date: record.booking_date || state.selectedDate,
            time: record.booking_time || "18:00",
            durationMinutes: 120,
            guests: Number(record.guests || 1),
            seatingType: record.seating_type || "table",
            assignedTables: [],
            assignedBarSeats: [],
            status: "confirmed",
            server: "Admin",
            source: "website",
            requests: record.requests || "",
            internalNote: "Imported from public reservation local save.",
            createdAt: record.created_at || new Date().toISOString(),
            updatedAt: new Date().toISOString()
          };
          reservation = autoAssign(reservation, reservation.id);
          state.data.reservations.push(reservation);
          imported += 1;
        });
        await AdminBackend.save(state.data);
        showMessage(`${imported} public saves imported.`, true);
        renderAll();
      }

      function customerFromPublic(record) {
        const name = `${record.first_name || ""} ${record.last_name || ""}`.trim() || "Website guest";
        return {
          id: uid("c"),
          name,
          email: record.email || "",
          phone: record.phone || "",
          tags: ["website"],
          profileNote: "Created from public reservation save.",
          createdAt: new Date().toISOString(),
          updatedAt: new Date().toISOString()
        };
      }

      function exportJson() {
        const blob = new Blob([JSON.stringify(state.data, null, 2)], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = `1820-admin-${state.selectedDate}.json`;
        link.click();
        URL.revokeObjectURL(url);
      }

      async function resetDemo() {
        state.data = await AdminBackend.resetDemo();
        state.selectedDate = todayIso();
        state.selectedReservationId = state.data.reservations.find((reservation) => reservation.date === state.selectedDate)?.id || "";
        state.selectedCustomerId = getReservation(state.selectedReservationId)?.customerId || state.data.customers[0]?.id || "";
        renderAll();
      }

      function toggleResourceWraps() {
        const table = dom.seatingType.value === "table";
        dom.tableResourceWrap.hidden = !table;
        dom.barResourceWrap.hidden = table;
      }

      function seatingLabel(value) {
        return value === "barstand" ? "Barstand" : "Table";
      }

      function statusLabel(value) {
        return String(value || "").replace("_", " ");
      }

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      async function init() {
        state.data = await AdminBackend.load();
        state.selectedDate = todayIso();
        const firstToday = state.data.reservations.find((reservation) => reservation.date === state.selectedDate);
        state.selectedReservationId = firstToday?.id || state.data.reservations[0]?.id || "";
        state.selectedCustomerId = firstToday?.customerId || state.data.customers[0]?.id || "";

        dom.form.addEventListener("submit", saveEditor);
        dom.adminDate.addEventListener("change", () => {
          state.selectedDate = dom.adminDate.value || todayIso();
          state.selectedReservationId = reservationsForDate(state.selectedDate)[0]?.id || "";
          renderAll();
        });
        dom.statusFilter.addEventListener("change", () => {
          state.status = dom.statusFilter.value;
          renderAll();
        });
        dom.serverFilter.addEventListener("change", () => {
          state.server = dom.serverFilter.value;
          renderAll();
        });
        dom.searchInput.addEventListener("input", () => {
          state.search = dom.searchInput.value;
          renderReservationTable();
        });
        dom.newReservationButton.addEventListener("click", () => {
          state.selectedReservationId = "";
          renderAll();
        });
        dom.importPublicButton.addEventListener("click", importPublicReservations);
        dom.exportButton.addEventListener("click", exportJson);
        dom.resetDemoButton.addEventListener("click", resetDemo);
        dom.duplicateButton.addEventListener("click", duplicateSelected);
        dom.autoSeatButton.addEventListener("click", applyAutoSeat);
        dom.cancelBookingButton.addEventListener("click", cancelSelected);
        dom.addClientNoteButton.addEventListener("click", addClientNote);
        [dom.bookingDate, dom.bookingTime, dom.durationMinutes, dom.guestCount, dom.seatingType].forEach((input) => {
          input.addEventListener("change", () => {
            const candidate = readEditor();
            renderResourceChoices(candidate);
            toggleResourceWraps();
            renderFloor();
          });
        });

        renderAll();
      }

      init().catch((error) => {
        console.error(error);
        document.body.insertAdjacentHTML("afterbegin", `<div class="message is-visible" style="position:fixed;z-index:100;left:20px;right:20px;top:20px;">Admin failed to load: ${escapeHtml(error.message)}</div>`);
      });
    })();
  </script>
</body>
</html>

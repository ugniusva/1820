          meta: { schemaVersion: 1, updatedAt: new Date().toISOString() },
          settings: { tableCoverLimit: TABLE_LIMIT, barCoverLimit: BAR_LIMIT },
          customers: [],
          reservations: [],
          notes: []
        };
        const next = { ...base, ...data };
        next.meta = { ...base.meta, ...(data.meta || {}) };
        next.settings = { ...base.settings, ...(data.settings || {}) };
        next.customers = Array.isArray(data.customers) ? data.customers : [];
        next.reservations = Array.isArray(data.reservations) ? data.reservations : [];
        next.notes = Array.isArray(data.notes) ? data.notes : [];
        return next;
      }


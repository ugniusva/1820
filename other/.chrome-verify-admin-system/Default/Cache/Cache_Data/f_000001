          reservation("r-006", "c-iev", today, "18:00", 4, "table", ["T4"], [], "confirmed", "Mara", "website", "Still water.", "Prefers table 4."),
          reservation("r-007", "c-roman", today, "19:00", 4, "table", ["T5"], [], "confirmed", "Jonas", "phone", "Client dinner.", "Wine list ready."),
          reservation("r-008", "c-elena", today, "20:00", 4, "table", ["T6"], [], "confirmed", "Ieva", "website", "Chef note.", "Greet by name."),
          reservation("r-009", "c-ugnius", today, "20:00", 4, "table", ["T1"], [], "confirmed", "Admin", "admin", "cheese", "Demo booking for dashboard review."),
          reservation("r-010", "c-lina", addDays(today, 1), "18:30", 2, "table", ["T2"], [], "confirmed", "Noa", "website", "Window.", "Birthday dessert possible."),
          reservation("r-011", "c-ada", addDays(today, -7), "19:30", 2, "table", ["T1"], [], "completed", "Mara", "website", "Quiet.", "Good pacing, asked about June menu."),
          reservation("r-012", "c-milas", addDays(today, -3), "20:30", 2, "barstand", [], ["B01", "B02"], "completed", "Jonas", "phone", "Bar.", "Ordered martinis twice."),
          reservation("r-013", "c-roman", addDays(today, 2), "19:00", 8, "table", ["T3", "T4"], [], "confirmed", "Dainius", "concierge", "Private business table.", "Group override: 8 guests, two tables."),
          reservation("r-014", "c-noor", addDays(today, 3), "21:00", 2, "table", ["T5"], [], "confirmed", "Ieva", "website", "Vegan.", "Plant-based tasting.")
        ];

        const notes = [
          note("n-001", "c-ada", "Mara", addDays(today, -7), "Handled shellfish allergy without needing reminder."),
          note("n-002", "c-milas", "Jonas", addDays(today, -3), "Prefers the bar to a table even when table space is open."),
          note("n-003", "c-ugnius", "Admin", today, "Demo note: likes cheese and a direct confirmation message."),

      function customer(id, name, email, phone, tags, profileNote) {
        return {
          id,
          name,
          email,
          phone,
          tags,
          profileNote,
          createdAt: new Date().toISOString(),
          updatedAt: new Date().toISOString()
        };
      }

      function reservation(id, customerId, date, time, guests, seatingType, assignedTables, assignedBarSeats, status, server, source, requests, internalNote) {
        return {
          id,
          customerId,
          date,
          time,
          durationMinutes: 120,
          guests,
          seatingType,
          assignedTables,
          assignedBarSeats,
          status,
          server,
          source,
          requests,
          internalNote,
          createdAt: new Date().toISOString(),
          updatedAt: new Date().toISOString()
        };
      }

      function note(id, customerId, author, dateIso, text) {
        return {
          id,
          customerId,
          author,
          text,
          createdAt: `${dateIso}T12:00:00.000Z`
        };
      }

      function getCustomer(id) {
        return state.data.customers.find((customer) => customer.id === id) || null;
      }

      function getReservation(id) {
        return state.data.reservations.find((reservation) => reservation.id === id) || null;
      }

      function isActive(reservation) {
        return ACTIVE_STATUSES.has(reservation.status);
      }

      function intervalOf(reservation) {
        const start = timeToMinutes(reservation.time);
        return { start, end: start + Number(reservation.durationMinutes || 120) };
      }

      function overlaps(a, b) {
        return a.start < b.end && b.start < a.end;
      }

      function reservationsForDate(date = state.selectedDate) {
        return state.data.reservations
          .filter((reservation) => reservation.date === date)
          .sort((a, b) => a.time.localeCompare(b.time));
      }

      function matchingReservations() {
        const search = state.search.trim().toLowerCase();
        return reservationsForDate().filter((reservation) => {
          const customer = getCustomer(reservation.customerId);
          const searchable = [
            customer?.name,
            customer?.email,
            customer?.phone,
            reservation.requests,
            reservation.internalNote,
            reservation.time,
            reservation.status,
            reservation.seatingType,
            resourcesLabel(reservation)
          ].filter(Boolean).join(" ").toLowerCase();
          return (state.status === "all" || reservation.status === state.status)
            && (state.server === "all" || reservation.server === state.server)
            && (!search || searchable.includes(search));
        });
      }

      function resourcesLabel(reservation) {
        if (reservation.seatingType === "barstand") {
          return reservation.assignedBarSeats?.length ? reservation.assignedBarSeats.join(", ") : "Unassigned bar";
        }
        return reservation.assignedTables?.length ? reservation.assignedTables.join(", ") : "Unassigned table";
      }

      function reservationsOverlapping(candidate, ignoreId = "") {
        const candidateInterval = intervalOf(candidate);
        return state.data.reservations.filter((reservation) => {
          if (reservation.id === ignoreId || reservation.date !== candidate.date || !isActive(reservation)) {
            return false;
          }
          return overlaps(candidateInterval, intervalOf(reservation));
        });
      }

      function occupancyAt(date, time) {
        const point = timeToMinutes(time);
        const tableReservations = [];
        const barReservations = [];
        reservationsForDate(date).forEach((reservation) => {
          if (!isActive(reservation)) {
            return;
          }
          const interval = intervalOf(reservation);
          if (point >= interval.start && point < interval.end) {
            if (reservation.seatingType === "barstand") {
              barReservations.push(reservation);
            } else {
              tableReservations.push(reservation);
            }
          }
        });
        return {
          tableCovers: tableReservations.reduce((sum, reservation) => sum + Number(reservation.guests || 0), 0),
          barCovers: barReservations.reduce((sum, reservation) => sum + Number(reservation.guests || 0), 0),
          tableReservations,
          barReservations
        };
      }

      function busyResources(candidate, ignoreId = "") {
        const overlapping = reservationsOverlapping(candidate, ignoreId);
        const tables = new Map();
        const bars = new Map();
        overlapping.forEach((reservation) => {
          const customer = getCustomer(reservation.customerId);
          (reservation.assignedTables || []).forEach((table) => tables.set(table, customer?.name || "Busy"));
          (reservation.assignedBarSeats || []).forEach((seat) => bars.set(seat, customer?.name || "Busy"));
        });
        return { tables, bars, overlapping };
      }

      function validateReservation(candidate, ignoreId = "") {
        const issues = [];
        const guests = Number(candidate.guests || 0);
        if (!candidate.customerId) {
          issues.push("Choose a client.");
        }
        if (!candidate.date) {
          issues.push("Choose a date.");
        }
        if (!candidate.time) {
          issues.push("Choose a time.");
        }
        if (guests < 1 || guests > 12) {
          issues.push("Guests must be between 1 and 12.");
        }

        const busy = busyResources(candidate, ignoreId);

        if (candidate.seatingType === "table") {
          const assigned = candidate.assignedTables || [];
          const tableCapacity = assigned.length * 4;
          if (tableCapacity < guests) {
            issues.push("Assigned tables do not cover the guest count.");
          }
          assigned.forEach((table) => {
            if (busy.tables.has(table)) {
              issues.push(`${table} is already booked at that time.`);
            }
          });
          const candidateInterval = intervalOf(candidate);
          for (let minutes = candidateInterval.start; minutes < candidateInterval.end; minutes += 15) {
            const time = minutesToTime(minutes);
            const current = occupancyAt(candidate.date, time).tableCovers;
            if (current + guests > TABLE_LIMIT) {
              issues.push(`Table covers exceed 12 at ${time}.`);
              break;
            }
          }
        } else {
          const assigned = candidate.assignedBarSeats || [];
          if (assigned.length < guests) {
            issues.push("Assigned bar spaces do not cover the guest count.");
          }
          assigned.forEach((seat) => {
            if (busy.bars.has(seat)) {
              issues.push(`${seat} is already booked at that time.`);
            }
          });
          const candidateInterval = intervalOf(candidate);
          for (let minutes = candidateInterval.start; minutes < candidateInterval.end; minutes += 15) {
            const time = minutesToTime(minutes);
            const current = occupancyAt(candidate.date, time).barCovers;
            if (current + guests > BAR_LIMIT) {
              issues.push(`Bar covers exceed 12 at ${time}.`);
              break;
            }
          }
        }
        return issues;
      }

      function autoAssign(candidate, ignoreId = "") {
        const busy = busyResources(candidate, ignoreId);
        const guests = Number(candidate.guests || 0);
        if (candidate.seatingType === "table") {
          const needed = Math.ceil(guests / 4);
          const open = TABLES.map((table) => table.id).filter((table) => !busy.tables.has(table));
          candidate.assignedTables = open.slice(0, needed);
          candidate.assignedBarSeats = [];
        } else {
          const open = BAR_SEATS.filter((seat) => !busy.bars.has(seat));
          candidate.assignedBarSeats = open.slice(0, guests);
          candidate.assignedTables = [];
        }
        return candidate;
      }

